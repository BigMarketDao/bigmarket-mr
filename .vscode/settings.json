{
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "typescript.tsdk": "node_modules/typescript/lib",
  "files.exclude": {
    "**/.pnpm": true,
    "**/dist": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true
  },
  "cSpell.words": [
    "AKWJYC",
    "QAHWFPGTVK",
    "XNXDB",
    "XXKPGP",
    "YVEK",
    "ZXGASRJ"
  ]
}
