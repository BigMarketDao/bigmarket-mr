{
  "name": "bigmarket",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "overrides": {
      "@noble/hashes": "^1.8.0"
    }
  },
  "scripts": {
    "dev": "pnpm --filter @bigmarket/frontend-c1 dev",
    "dev-api": "pnpm --filter @bigmarket/api-v1 dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "resolve": "^1.22.12",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@noble/hashes": "1.3.2"
  }
}
