# BigMarket agent skill — testnet environment
# Copy to agents/.env.testnet and run:  source agents/.env.testnet
#
# Do not commit agents/.env.testnet if it contains secrets.

# --- Required ---
export BIGMARKET_NETWORK=testnet

# --- BANG (Phase 10 only — leave commented until contracts are deployed) ---
# export BIGMARKET_BANG_ENABLED=true
# export BIGMARKET_BANG_CONTRACT=ST30Q4WJYHGMYEE1CTGQ334R9M7KQ8ETVQ9NB134T.your-bang-token
# export BIGMARKET_BANG_GATE_CONTRACT=ST30Q4WJYHGMYEE1CTGQ334R9M7KQ8ETVQ9NB134T.your-bang-market-gate
# export BIGMARKET_BANG_CLAIM_CONTRACT=ST30Q4WJYHGMYEE1CTGQ334R9M7KQ8ETVQ9NB134T.your-bang-claim

# --- Dev only: skip --confirm on writes ---
# export BIGMARKET_AUTO_CONFIRM=true

